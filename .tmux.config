set -g mouse on

setw -g mode-keys vi

# Transparencia y truecolor
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256col*:Tc"
set -ga terminal-overrides ",*:RGB"
set -ga terminal-overrides ",*:Smulx=\\E[4::%p1%dm"
# Habilitar fondo transparente (AX = fondo por defecto del terminal)
set -ga terminal-overrides ",*:AX"
# Permitir passthrough de secuencias de escape (necesario para apps como opencode)
set -g allow-passthrough on

# Hacer que las nuevas ventanas y paneles se abran en el directorio actual
bind '"' split-window -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# Hook para ejecutar z al crear una nueva sesión
set-hook -g session-created 'run-shell "tmux send-keys -t \"#{session_name}\":1 \"z #{session_name} 2>/dev/null || true\" C-m"'

# Binding para crear una nueva sesión con z automático
bind C-n command-prompt -p "Nombre del proyecto:" "run-shell 'bash -c \"project_dir=\\$(zoxide query %% 2>/dev/null); if [ -n \\\"\\$project_dir\\\" ]; then tmux new-session -d -s %% -c \\\"\\$project_dir\\\"; tmux switch-client -t %%; else echo \\\"Proyecto no encontrado en zoxide\\\"; fi\"'"

#plugin manager

set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g status-position top

#pop shell
bind C-g display-popup -E "ta ~/git"
bind -n M-g display-popup -E "tmux new-session -A -s scratch"
bind t display-popup -d "#{pane_current_path}" -w 80% -h 80% -E "tmux new-session -A -s floating"

# Other examples:
# set -g @plugin 'github_username/plugin_name'
# set -g @plugin 'github_username/plugin_name#branch'
# set -g @plugin 'git@github.com:user/plugin'
# set -g @plugin 'git@bitbucket.com:user/plugin'
set -g @kanagawa-plugins "cpu-usage ram-usage time"
# set -g @dracula-show-right-sep 
set -g @kanagawa-show-powerline true
set -g @kanagawa-show-timezone false

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'

set -g @plugin "nordtheme/tmux"

# clip conf 
# Usa xclip para copiar al portapapeles del sistema
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in"
bind-key -T copy-mode y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard -in"

# Permite seleccionar texto con el mouse para copiar al portapapeles
set-option -g mouse on
